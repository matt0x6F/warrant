# Server
PORT=8080

# Database (use postgres:5432 when running inside Docker Compose)
DATABASE_URL=postgres://warrant:warrant@postgres:5432/warrant?sslmode=disable

# Redis (use redis:6379 when running inside Docker Compose)
REDIS_URL=redis://redis:6379/0

# GitHub OAuth2 (required for sign-in and MCP URL auth). Do not commit real values.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=

# Optional: public base URL (defaults to http://localhost:PORT)
# BASE_URL=http://localhost:8080

# Optional: redirect here after login with ?token=... instead of showing token page
# AUTH_SUCCESS_REDIRECT_URL=

# Optional: queue lease TTL in minutes (default 10)
# LEASE_TTL_MINUTES=10

# Optional: run objective.acceptance_test (shell command) on submit_ticket; if it fails, submit is rejected (default false)
# RUN_ACCEPTANCE_TEST_ON_SUBMIT=true
